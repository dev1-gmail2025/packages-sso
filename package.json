{
  "name": "sevago-sso-fe",
  "version": "1.0.166",
  "description": "Sevago SSO Frontend Library - A comprehensive SSO solution with React components",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode library",
    "prepare": "npm run build",
    "build:lib": "vite build --mode library",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006 --disable-telemetry",
    "build-storybook": "storybook build -o docs && touch docs/.nojekyll",
    "storybook:test": "test-storybook --url http://127.0.0.1:6006",
    "storybook:test:ci": "start-server-and-test storybook http://127.0.0.1:6006 storybook:test",
    "chromatic": "chromatic --project-token=$CHROMATIC_PROJECT_TOKEN --exit-zero-on-changes --only-changed",
    "prepublishOnly": "npm run build:lib",
    "format": "prettier --write src/**/*.{js,jsx,ts,tsx,json,css,md}",
    "version:patch": "npm version patch",
    "version:publish": "npm version patch && npm publish --access public"
  },
  "keywords": [
    "sso",
    "authentication",
    "react",
    "typescript",
    "sevago"
  ],
  "author": "Sevago Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dev1-gmail2025/sevago-sso-fe"
  },
  "bugs": {
    "url": "https://github.com/dev1-gmail2025/sevago-sso-fe"
  },
  "homepage": "https://github.com/dev1-gmail2025/sevago-sso-fe",
  "peerDependencies": {
    "@emotion/react": ">=11",
    "@emotion/styled": ">=11",
    "@mui/material": ">=5",
    "@mui/system": ">=5",
    "@mui/x-date-pickers": "^8.2.0",
    "@reduxjs/toolkit": "^2.9.2",
    "@types/react-router-dom": "^5.3.3",
    "axios": "^1.12.2",
    "dayjs": "^1.11.18",
    "formik": "^2.4.6",
    "framer-motion": "^12.23.22",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-number-format": "^5.4.3",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.9.5",
    "redux-persist": "^6.0.0",
    "socket.io-client": "^4.8.1",
    "yup": "^1.7.1"
  },
  "dependencies": {
    "@storybook/core-events": "^8.6.14",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@mui/x-date-pickers": "^8.2.0",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/addon-links": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@storybook/test-runner": "^0.22.0",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^24.7.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.12.2",
    "chromatic": "^11.29.0",
    "dayjs": "^1.11.18",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "formik": "^2.4.6",
    "framer-motion": "^12.23.22",
    "globals": "^16.4.0",
